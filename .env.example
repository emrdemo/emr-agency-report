# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill it in.  `.env` is gitignored — never commit it.
#
#   cp .env.example .env
#
# Everything below is read at runtime; nothing here is hard-coded in the source.
# ─────────────────────────────────────────────────────────────────────────────

# ── API ──────────────────────────────────────────────────────────────────────
# Your EmbedMyReviews (EMR) app host — just the scheme + domain, no trailing slash
# and no path. The tool appends the right paths itself: the Reviews MCP at
# {host}/api/mcp and the Agency REST API at {host}/api/agency/v1/... Set this to
# your own white-label domain.
EMR_BASE_URL=https://app.your-white-label.com

# MCP token — the bearer token from your EmbedMyReviews MCP connection (the same
# token your MCP client / .mcp.json uses). Powers AI Insights, review metrics,
# reviews, and GBP via {host}/api/mcp. Required.
EMR_MCP_TOKEN=

# Agency / tenant-owner token — required for the Local Search Grid (LSG) pages
# (map, search performance, competitors). This is an AGENCY-level token, not a
# customer token. If you leave it blank the report still renders, but the
# LSG-powered sections fall back to an empty state.
EMR_TENANT_API_TOKEN=

# ── Your agency branding (white-label) ───────────────────────────────────────
# These set the cover wordmark, the strapline, the accent colour, and the
# footers. They apply to both live reports and the bundled demo, so you can run
# `npm run report:demo` and immediately see the sample report in your own brand.
# All optional — anything left blank falls back to a neutral default.
AGENCY_NAME=Your Agency
AGENCY_TAGLINE=Local Search & Reputation

# Accent colour (any CSS colour). ACCENT is the strong brand colour used for
# headings/rules; ACCENT_SOFT is a pale tint used for highlighted table rows.
# Quote hex values — a leading "#" is otherwise read as a comment and ignored.
AGENCY_ACCENT="#15554a"
AGENCY_ACCENT_SOFT="#ecf2ee"

# Optional logo shown on the cover instead of the wordmark. Must be a public URL
# (it is fetched by the headless browser at PDF render time). Leave blank to use
# the AGENCY_NAME wordmark.
AGENCY_LOGO_URL=

# ── This report: which client + which month ──────────────────────────────────
# The values for ONE client location — change these each time you run a report.
# See the README for how to get the IDs (organization + location come from your
# MCP; the scan UUID comes from the Agency API or the EMR app).

# EmbedMyReviews organization + location IDs (numbers).
EMR_ORGANIZATION_ID=
EMR_LOCATION_ID=

# The Local Search Grid scan for this location, plus the keyword it tracks that
# you want the map + competitor pages built around.
EMR_SCAN_UUID=
EMR_SCAN_KEYWORD=

# How the client is labelled on the cover + footers.
BUSINESS_NAME=Example Client Ltd
BUSINESS_LOCATION_LABEL=City / Area

# Month the report covers (YYYY-MM). Leave blank to use the previous complete
# month — e.g. running it any time in June produces the May report. Override a
# single run with:  node src/index.js --month=2026-04
REPORT_MONTH=

# ── Advanced (optional — sensible defaults, uncomment to change) ──────────────
# REPORT_LOCALE=en-US
# EMR_INCLUDE_GBP=true        # set false to skip Google Business Profile pulls
# EMR_HIGHLIGHT_COUNT=4       # verbatim quotes to surface on the reviews page
# EMR_COMPETITOR_LIMIT=8      # competitors to show in the landscape table
